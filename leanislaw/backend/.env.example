# Copy to .env in this folder (or set in your shell). Required for production.
JWT_SECRET=use-a-long-random-string-in-production

# Resend — verification & password-reset emails (https://resend.com/api-keys)
# Key must start with re_ — add exactly this line name (not RESEND_KEY unless you export it yourself).
RESEND_API_KEY=
# Sender must be a domain you've verified in Resend, or use Resend's test sender:
# EMAIL_FROM=Lean Is Law <onboarding@resend.dev>
EMAIL_FROM=
USDA_API_KEY=your-usda-fooddata-central-api-key
OPENAI_API_KEY=your-openai-api-key
OPENAI_MODEL=gpt-4o-mini
PORT=4000
# Comma-separated list of allowed frontend origins in production
# Example: CORS_ORIGINS=https://leanislaw.app,https://www.leanislaw.app
CORS_ORIGINS=

# Stripe (premium coaching) — https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
# Public frontend URL (no trailing slash), e.g. https://your-app.vercel.app
FRONTEND_URL=
# Recurring price IDs (GBP): monthly, every 6 months, yearly
STRIPE_PRICE_ID_MONTHLY=
STRIPE_PRICE_ID_SEMIANNUAL=
STRIPE_PRICE_ID_YEARLY=

# Chad chat: comma-separated knowledge source ids (see npm run ingest:knowledge:local)
# CHAD_KNOWLEDGE_SOURCES=bodyrecomposition,rapid_fat_loss
# After ingesting text/PDF, run: npm run embed:knowledge  (needs OPENAI_API_KEY for semantic search)
# CHAD_USE_SEMANTIC_KNOWLEDGE=false  # set to disable embedding-based retrieval
# CHAD_PRINCIPLES_PATH=   # optional absolute path to a principles file; or use backend/knowledge/chad-core-principles.txt
