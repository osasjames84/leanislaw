# Web app URL (no trailing slash). Simulator: http://localhost:5173
# EXPO_PUBLIC_WEB_URL=http://192.168.x.x:5173

# iOS Simulator only: skip typing password — injects creds and calls login() for you.
# Requires a real account on your API. Never commit real passwords to git; use .env.local.
# EXPO_PUBLIC_SIM_AUTO_LOGIN=1
# EXPO_PUBLIC_SIM_LOGIN_EMAIL=you@example.com
# EXPO_PUBLIC_SIM_LOGIN_PASSWORD=
